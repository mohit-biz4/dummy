# Firebase App Distribution
FIREBASE_APP_ID=1:123456789:android:abcdef     # Firebase App ID (Project Settings → Your Apps)
FIREBASE_TOKEN=your-firebase-ci-token           # From: firebase login:ci

# Google Play Store (optional, for production deploys)
PLAY_STORE_JSON_KEY=path/to/play-store-key.json # Service account JSON key

# Android Signing (optional, for release builds)
ANDROID_KEYSTORE_BASE64=                        # Base64-encoded release keystore
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
